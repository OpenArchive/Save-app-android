<?xml version="1.0" encoding="utf-8"?>
<androidx.core.view.insets.ProtectionLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:animateLayoutChanges="true">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="@color/colorTertiary"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/skip_button"
                android:insetTop="32dp"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp"
                android:text="@string/skip"
                android:textAppearance="@style/TextAppearance.SaveApp.16pt"
                android:textColor="@color/colorOnBackground" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="24dp"
                android:contentDescription="@string/next"
                app:backgroundTint="@color/colorPrimaryBright"
                app:srcCompat="@drawable/ic_arrow_right"
                app:tint="@color/colorOnBackground" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            android:orientation="vertical"
            android:weightSum="125">

            <View
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="8" />

            <ImageView
                android:id="@+id/coverImage"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_gravity="start"
                android:layout_weight="65"
                android:paddingEnd="40dp"
                tools:ignore="RtlSymmetry"
                tools:src="@drawable/onboarding_encrypt_png" />

            <View
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="37" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="15">

                <com.tbuonomo.viewpagerdotsindicator.WormDotsIndicator
                    android:id="@+id/dots_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    app:dotsClickable="false"
                    app:dotsColor="@color/colorOnBackground"
                    app:dotsCornerRadius="5dp"
                    app:dotsSize="10dp"
                    app:dotsSpacing="7dp"
                    app:dotsStrokeColor="@color/c23_medium_grey"
                    app:dotsStrokeWidth="5dp" />

            </FrameLayout>

        </LinearLayout>

    </FrameLayout>
</androidx.core.view.insets.ProtectionLayout>